{
    "name": "ho-control-xapp",
    "version": "0.0.119",
    "appInstanceName": "ho-control-xapp",
    "containers": [
        {
            "name": "ho-control-xapp",
            "image": {
                "registry": "docker.io",
                "name": "zhria/handover_app",
                "tag": "0.0.119"
            },
            "imagePullPolicy": "Always"
        }
    ],
    "messaging": {
        "ports": [
            {
                "name": "http",
                "container": "ho-control-xapp",
                "port": 8080,
                "description": "http service"
            },
            {
                "name": "rmrroute",
                "container": "ho-control-xapp",
                "port": 4561,
                "description": "rc route port"
            },
            {
                "name": "rmrdata",
                "container": "ho-control-xapp",
                "port": 4560,
                "rxMessages": [
                    "RIC_SUB_RESP",
                    "RIC_SUB_FAILURE",
                    "RIC_SUB_DEL_RESP",
                    "RIC_CONTROL_ACK",
                    "RIC_CONTROL_FAILURE"
                ],
                "txMessages": [
                    "RIC_SUB_REQ",
                    "RIC_SUB_DEL_REQ",
                    "RIC_CONTROL_REQ"
                ],
                "policies": [
                    1
                ],
                "description": "rmr data port for rc-xapp"
            }
        ]
    },
    "controls": {
        "subscription": {
            "url": "http://service-ricxapp-ho-control-xapp-http:8080/",
            "clientEndpoint": "service-ricxapp-ho-control-xapp-http"
        }
    }
}
